#!/bin/bash

# Steam needs the contrib and non-free components, make sure they are enabled.
if ! grep -Rq "non-free" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
    echo "Enabling contrib, non-free and non-free-firmware components..."
    sudo sed -i 's/^\(deb.*main\)$/\1 contrib non-free non-free-firmware/' /etc/apt/sources.list
fi

# Ask user if they want to install Steam
read -p "Do you want to install Steam? (y/n): " steam_answer
if [[ $steam_answer == [Yy]* ]]; then
    echo "Installing Steam..."

    sudo dpkg --add-architecture i386
    sudo apt update
    sudo apt install wine wine64 wine32:i386 libasound2-plugins:i386 libsdl2-2.0-0:i386 libdbus-1-3:i386 \
    libsqlite3-0:i386
    # Since Debian 12, the Steam package is called steam-installer
    sudo apt install steam-installer mangohud gamemode

    echo "Steam installation completed."
else
    echo "Steam installation skipped."
fi

echo "Steam installation process finished."

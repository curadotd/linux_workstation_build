#!/bin/bash

# Hyprland is packaged in Debian 13 (trixie) and newer,
# so there is no longer any need to build it from source.

echo "Installing Hyprland and SDDM on Debian..."
sudo apt update
sudo apt install hyprland xdg-desktop-portal-hyprland xwayland waybar sddm qt6ct \
wl-clipboard dunst pavucontrol rofi grim slurp pamixer playerctl jq kitty

# Newer Hyprland ecosystem tools; not all of them are packaged in every
# Debian release, install what is available and warn about the rest.
for pkg in hyprpaper hyprlock hypridle cliphist; do
    sudo apt install "$pkg" || echo "WARNING: $pkg is not available on this Debian release, install it manually if needed."
done

echo "Note: hyprshot is not packaged on Debian, grim+slurp are installed as the screenshot fallback."
echo "Hyprland and SDDM installation completed."

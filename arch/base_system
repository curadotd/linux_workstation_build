#!/bin/bash

# Always run from the directory this script lives in,
# so sibling scripts are found no matter where it is called from
cd "$(dirname "$0")" || exit 1

# Base system setup for Arch Linux.

if [ ! -f /etc/arch-release ]; then
    echo "This script is for Arch Linux only. Use the folder matching your distribution."
    exit 1
fi

current_dir=$(pwd)

# Check if GIT_PATH is already set
if [ -z "$GIT_PATH" ]; then
    read -p "Enter the path for git repositories (default: $HOME/git): " git_path
    GIT_PATH=${git_path:-$HOME/git}
    export GIT_PATH

    if [ ! -d "$GIT_PATH" ]; then
        mkdir -p "$GIT_PATH"
        echo "Created git directory at $GIT_PATH"
    else
        echo "Git directory already exists at $GIT_PATH"
    fi
else
    echo "GIT_PATH is already set to $GIT_PATH"
fi

# Update and upgrade
echo "Running update and upgrade"
sudo pacman -Syu

# Install base libraries
echo "Install base libraries"
sudo pacman -S --needed tar tree tldr trash-cli unzip make jq papirus-icon-theme \
noto-fonts-emoji lm_sensors thunar xorg-apps xdg-utils xorg-xinput rofi wget github-cli \
alsa-plugins alsa-utils alsa-oss alsa-firmware plocate krita gimp qt5ct kvantum-qt5 fastfetch openssh gedit \
bash-completion vlc tumbler jpegoptim kitty ffmpeg ffmpegthumbs imagemagick pipewire-pulse htop

# Ask user if they want to install yay
read -p "Do you want to install yay (AUR helper)? (y/n) " install_yay
if [[ $install_yay =~ ^[Yy]$ ]]; then
    echo "Installing yay..."
    ./install_yay
else
    echo "Skipping yay installation."
fi

./install_fonts

# Ask user about desktop environment
echo "Which desktop environment would you like to install?"
echo "1) DWM"
echo "2) Hyprland"
echo "3) MATE"
echo "4) KDE"
echo "5) None"
read -p "Enter your choice (1/2/3/4/5): " de_choice

case $de_choice in
    1)
        ./install_dwm
        ;;
    2)
        ./install_hyprland
        ;;
    3)
        ./install_mate_desktop
        ;;
    4)
        ./install_plasma_desktop
        ;;
    5)
        echo "Skipping desktop environment installation."
        ;;
    *)
        echo "Invalid choice. Skipping desktop environment installation."
        ;;
esac

cd $current_dir

./install_display_manager
./install_starship
./clone_dotconfig
./install_mactahoe_theme
./setup_qt

cd $current_dir

./install_web_browser
./install_steam
./setup_nfs_drives

cd $current_dir

echo "Setup is now completed, please reboot your system."

#!/bin/bash

# Always run from the directory this script lives in,
# so sibling scripts are found no matter where it is called from
cd "$(dirname "$0")" || exit 1

# Ask user if they want to install Parsec
read -p "Do you want to install Parsec? (y/n): " install_choice

if [[ $install_choice =~ ^[Yy]$ ]]; then
    echo "Installing Parsec from the AUR..."
    if ! command -v yay &> /dev/null; then
        ./install_yay
    fi
    yay -S --needed parsec-bin
    echo "Parsec installation completed."
else
    echo "Parsec installation skipped."
fi

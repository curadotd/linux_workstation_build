#!/bin/bash

# Parsec only publishes an official .deb (their own CDN, Ubuntu-targeted).
# There is no RPM, so the .deb contents are extracted and installed directly:
#   /usr/bin/parsecd
#   /usr/share/applications/parsecd.desktop
#   /usr/share/icons/hicolor/256x256/apps/parsecd.png
#   /usr/share/parsec/skel/*
# To uninstall, remove those paths.

# Ask user if they want to install Parsec
read -p "Do you want to install Parsec? (y/n): " install_choice

if [[ $install_choice =~ ^[Yy]$ ]]; then
    # Runtime libraries from the official repos (most are present on a desktop install)
    sudo dnf install alsa-lib libX11 libXcursor libXi libSM mesa-libGL libjpeg-turbo libpng libcurl \
    binutils tar zstd

    # Parsec dlopens libjpeg.so.8 (Ubuntu ABI) at runtime; Fedora/EL only ship
    # libjpeg.so.62. Build the jpeg8 ABI from the official libjpeg-turbo
    # upstream (only the jpeg target - turbojpeg is not needed) and install it
    # alongside the system library.
    if ! ldconfig -p | grep -q "libjpeg\.so\.8 "; then
        echo "Building libjpeg (jpeg8 ABI) from the official libjpeg-turbo source..."
        sudo dnf install cmake nasm gcc git
        tmp_jpeg=$(mktemp -d)
        git clone --branch 3.2.0 --depth 1 https://github.com/libjpeg-turbo/libjpeg-turbo.git "$tmp_jpeg"
        cd "$tmp_jpeg" || exit 1
        cmake -B build -DCMAKE_BUILD_TYPE=Release -DWITH_JPEG8=1
        cmake --build build --target jpeg -j$(nproc)
        sudo install -m 755 build/libjpeg.so.8.* /usr/lib64/
        sudo ln -sf "$(basename build/libjpeg.so.8.*)" /usr/lib64/libjpeg.so.8
        sudo ldconfig
        cd /
        rm -rf "$tmp_jpeg"
    fi

    echo "Downloading Parsec from the official vendor CDN..."
    tmp_dir=$(mktemp -d)
    cd "$tmp_dir" || exit 1
    curl -sO https://builds.parsec.app/package/parsec-linux.deb
    ar x parsec-linux.deb
    tar xf data.tar.*

    sudo cp -r usr/* /usr/

    cd /
    rm -rf "$tmp_dir"

    # Parsec's own AUR package (parsec-bin) pins a hard dependency on
    # ffmpeg4.4, not "ffmpeg". Its parsecd binary dlopens libavcodec by a
    # bare soname (whatever it finds), and on Fedora/EL that resolves to the
    # current system ffmpeg (8.x, libavcodec.so.62) instead - which loads
    # fine but is ABI-incompatible with what parsecd was actually built
    # against, causing every stream to fail with "decode_frame = -17" and
    # an empty decoder list, with no visible error anywhere. Confirmed by
    # building the official ffmpeg n4.4 release (matching the AUR pin)
    # into a private prefix and pointing ONLY parsecd at it via
    # LD_LIBRARY_PATH in the wrapper below - the system-wide ffmpeg 8.x
    # used by everything else on the machine is untouched.
    FFMPEG44_PREFIX="/opt/parsec-ffmpeg4.4"
    if [ ! -f "$FFMPEG44_PREFIX/lib/libavcodec.so.58" ]; then
        echo "Building ffmpeg 4.4 (Parsec's required ABI) from the official FFmpeg source..."
        sudo dnf install nasm gcc make git pkgconf-pkg-config
        tmp_ffmpeg=$(mktemp -d)
        git clone --depth 1 --branch n4.4 https://github.com/FFmpeg/FFmpeg.git "$tmp_ffmpeg"
        cd "$tmp_ffmpeg" || exit 1
        # --disable-inline-asm: ffmpeg 4.4's GCC-style inline asm in
        # mathops.h fails to assemble on Fedora 44's newer binutils
        # ("operand type mismatch for `shr`"). The separately-assembled
        # NASM SIMD codecs (the actual decode hot path) are unaffected.
        ./configure --prefix="$tmp_ffmpeg/install" --enable-shared --disable-static \
        --disable-doc --disable-programs --disable-vaapi --disable-vdpau --disable-inline-asm
        make -j"$(nproc)"
        make install
        sudo mkdir -p "$FFMPEG44_PREFIX"
        sudo cp -P "$tmp_ffmpeg"/install/lib/*.so* "$FFMPEG44_PREFIX/"
        cd /
        rm -rf "$tmp_ffmpeg"
    else
        echo "ffmpeg 4.4 already built for Parsec, skipping."
    fi

    # Wrapper so the desktop entry / any launcher (rofi, SUPER+A, etc.)
    # picks up the private ffmpeg 4.4 automatically
    sudo mv /usr/bin/parsecd /usr/bin/parsecd.real
    sudo tee /usr/bin/parsecd > /dev/null << EOF
#!/bin/bash
export LD_LIBRARY_PATH="$FFMPEG44_PREFIX\${LD_LIBRARY_PATH:+:\$LD_LIBRARY_PATH}"
exec /usr/bin/parsecd.real "\$@"
EOF
    sudo chmod 755 /usr/bin/parsecd

    # Sanity check
    if command -v parsecd > /dev/null && ! ldd /usr/bin/parsecd.real | grep -q "not found"; then
        echo "Parsec installation completed. Launch with: parsecd"
    else
        echo "WARNING: parsecd installed but some libraries did not resolve, run: ldd /usr/bin/parsecd.real"
    fi
else
    echo "Parsec installation skipped."
fi

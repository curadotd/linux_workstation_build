#!/bin/bash

# First install script for Rocky Linux 9.
# Installs development tools, graphics drivers and base utilities.

if [ ! -f /etc/rocky-release ]; then
    echo "This script is for Rocky Linux only. Use the folder matching your distribution."
    exit 1
fi

# Install development tools and other necessary packages
sudo dnf groupinstall "Development Tools"
sudo dnf install epel-release
sudo dnf install gcc gcc-c++ kernel-devel kernel-headers glibc-devel.i686 libgcc.i686 tar tree \
unzip cmake make jq pciutils

# Ask if the user wants to enable the CRB (CodeReady Builder) repository,
# it is needed for many development packages.
read -p "Do you want to enable the CRB (CodeReady Builder) repository? Recommended. (y/n): " crb_choice
if [[ "$crb_choice" == "y" ]]; then
    echo "Enabling CRB repository for Rocky Linux..."
    sudo dnf config-manager --set-enabled crb
    sudo dnf upgrade
else
    echo "Continuing without the CRB repository."
fi

# Ask user if they want to install graphics drivers
read -p "Do you want to install graphics drivers? (y/n) " install_drivers
if [[ $install_drivers =~ ^[Yy]$ ]]; then
    if lspci | grep -i nvidia > /dev/null; then
        echo "NVIDIA GPU detected. Installing NVIDIA drivers from the CUDA repository..."
        sudo dnf config-manager --add-repo https://developer.download.nvidia.com/compute/cuda/repos/rhel9/x86_64/cuda-rhel9.repo
        # NVIDIA now recommends the open kernel modules for Turing and newer GPUs.
        # Use nvidia-driver:latest-dkms instead if you have an older card.
        sudo dnf module install nvidia-driver:open-dkms
        sudo dnf install nvidia-settings cuda

        # Add NVIDIA modules to /etc/modules-load.d/nvidia.conf
        if [ ! -f /etc/modules-load.d/nvidia.conf ]; then
            echo -e "nvidia\nnvidia_modeset\nnvidia_uvm\nnvidia_drm" | sudo tee /etc/modules-load.d/nvidia.conf
            echo "NVIDIA modules added to /etc/modules-load.d/nvidia.conf"
        else
            echo "NVIDIA modules already present in /etc/modules-load.d/nvidia.conf"
        fi

        # Create or update /etc/modprobe.d/nvidia.conf
        echo "options nvidia_drm modeset=1 fbdev=1" | sudo tee /etc/modprobe.d/nvidia.conf
        echo "NVIDIA options added to /etc/modprobe.d/nvidia.conf"

        sudo dracut --force
    elif lspci | grep -i amd > /dev/null; then
        echo "AMD GPU detected. Installing AMD drivers..."
        sudo dnf install mesa-dri-drivers mesa-vulkan-drivers vulkan-tools
    elif lspci | grep -i intel > /dev/null; then
        echo "Intel GPU detected. Installing Intel drivers..."
        sudo dnf install intel-media-driver mesa-vulkan-drivers
    else
        echo "No supported GPU detected. Please check your hardware."
    fi
else
    echo "Skipping graphics driver installation."
fi

# Clean up
sudo dnf autoremove
sudo dnf clean all

# Check if video group exists and add user to it
if getent group video > /dev/null 2>&1; then
    sudo usermod -aG video $USER
    echo "User added to video group."
else
    echo "Video group does not exist. Skipping."
fi

read -p "Do you want to reboot the system now? (y/n): " reboot_choice
if [[ "$reboot_choice" == "y" ]]; then
    echo "Rebooting the system..."
    sudo reboot
else
    echo "Reboot skipped. Please reboot manually later."
fi

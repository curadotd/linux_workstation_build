#!/bin/bash

# Ask user if they want to install Slack
read -p "Do you want to install Slack? (y/n): " install_choice

if [[ $install_choice =~ ^[Yy]$ ]]; then
    FILE="slack-*.x86_64.rpm"

    echo "Please download the Slack .rpm from:"
    echo "https://slack.com/downloads/linux"
    echo "and save it to your $HOME/Downloads folder."
    read -p "Press Enter when you have completed this step."

    # Check if the file exists
    if [ -z "$(ls $HOME/Downloads/$FILE 2>/dev/null)" ]; then
        echo "File not found in $HOME/Downloads. Exiting."
        exit 1
    fi

    ACTUAL_FILE=$(ls -t $HOME/Downloads/$FILE | head -n 1)

    sudo dnf install "$ACTUAL_FILE"

    # Slack's rpm auto-adds /etc/yum.repos.d/slack.repo (packagecloud.io, Slack's own
    # vendor repo) hardcoding sslcacert=/etc/pki/tls/certs/ca-bundle.crt - a legacy path
    # this Fedora release no longer populates (ca-certificates only ships
    # /etc/ssl/certs/ca-bundle.crt and the ca-trust-extracted bundles), which makes dnf
    # fail with a curl SSL error refreshing that repo. Recreate the compatibility symlink.
    if [ ! -e /etc/pki/tls/certs/ca-bundle.crt ] && [ -f /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem ]; then
        sudo ln -sf /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem /etc/pki/tls/certs/ca-bundle.crt
    fi

    echo "Slack installation completed."
else
    echo "Slack installation skipped."
fi

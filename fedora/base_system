#!/bin/bash

# Always run from the directory this script lives in,
# so sibling scripts are found no matter where it is called from
cd "$(dirname "$0")" || exit 1

# Base system setup for Fedora 44.

if [ ! -f /etc/fedora-release ]; then
    echo "This script is for Fedora only. Use the folder matching your distribution."
    exit 1
fi

current_dir=$(pwd)

# Check if GIT_PATH is already set
if [ -z "$GIT_PATH" ]; then
    read -p "Enter the path for git repositories (default: $HOME/git): " git_path
    GIT_PATH=${git_path:-$HOME/git}
    export GIT_PATH

    if [ ! -d "$GIT_PATH" ]; then
        mkdir -p "$GIT_PATH"
        echo "Created git directory at $GIT_PATH"
    else
        echo "Git directory already exists at $GIT_PATH"
    fi
else
    echo "GIT_PATH is already set to $GIT_PATH"
fi

# Update and upgrade
echo "Running update and upgrade"
sudo dnf upgrade

# Enable RPM Fusion free and nonfree, needed for full ffmpeg, Steam, etc.
if ! rpm -q rpmfusion-free-release > /dev/null 2>&1; then
    echo "Enabling RPM Fusion repositories..."
    sudo dnf install https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
    https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm
fi

# Install base libraries
echo "Install base libraries"
sudo dnf install tar tree tldr trash-cli unzip make jq papirus-icon-theme \
google-noto-color-emoji-fonts lm_sensors thunar tumbler xdg-utils xinput xsetroot xrandr rofi wget gh \
alsa-utils plocate krita gimp qt5ct kvantum gedit vlc kitty fastfetch htop bash-completion \
openssh ImageMagick jpegoptim

# Swap ffmpeg-free for the full ffmpeg from RPM Fusion
sudo dnf swap ffmpeg-free ffmpeg --allowerasing 2>/dev/null || sudo dnf install ffmpeg

./install_fonts

# Ask user about desktop environment
echo "Which desktop environment would you like to install?"
echo "1) DWM"
echo "2) Hyprland"
echo "3) MATE"
echo "4) KDE"
echo "5) None"
read -p "Enter your choice (1/2/3/4/5): " de_choice

case $de_choice in
    1)
        ./install_dwm
        ;;
    2)
        ./install_hyprland
        ;;
    3)
        ./install_mate_desktop
        ;;
    4)
        ./install_plasma_desktop
        ;;
    5)
        echo "Skipping desktop environment installation."
        ;;
    *)
        echo "Invalid choice. Skipping desktop environment installation."
        ;;
esac

cd $current_dir

./install_display_manager
./install_starship
./clone_dotconfig
./install_mactahoe_theme
./setup_qt

cd $current_dir

./install_web_browser
./install_steam
./setup_nfs_drives

cd $current_dir

echo "Setup is now completed, please reboot your system."
